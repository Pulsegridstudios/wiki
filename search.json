---
layout: none
---
[
  {% assign wiki_pages = site.html_pages | where: "layout", "wiki" %}
  {% for p in wiki_pages %}
  {
    "title": {{ p.title | jsonify }},
    "url": {{ p.url | relative_url | jsonify }},
    "content": {{ p.content | markdownify | strip_html | normalize_whitespace | jsonify }},
    "nav_group": {{ p.nav_group | jsonify }}
  }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]